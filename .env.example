# Supabase — Project Settings → API  (https://supabase.com/dashboard/project/_/settings/api)
# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser (safe: anon key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC. Only needed for privileged/admin tasks.
# SUPABASE_SERVICE_ROLE_KEY=
