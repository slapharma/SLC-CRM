# Supabase — Project Settings → API  (https://supabase.com/dashboard/project/_/settings/api)
# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser (safe: anon key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC. Only needed for privileged/admin tasks.
# SUPABASE_SERVICE_ROLE_KEY=

# Google Maps — https://console.cloud.google.com/google/maps-apis
# Enable billing, then enable these 3 APIs: Maps JavaScript API, Geocoding API, Maps Static API.
# Browser key: exposed to the browser — restrict by HTTP referrer + to the Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server key: NEVER prefix with NEXT_PUBLIC. Restrict to the Geocoding API + Maps Static API.
GOOGLE_MAPS_SERVER_KEY=

# KYC — UK company due diligence.
# Companies House Public Data API: free key from
# https://developer.company-information.service.gov.uk (Register → create an application →
# generate a REST API key). Server-only; NEVER prefix with NEXT_PUBLIC.
COMPANIES_HOUSE_API_KEY=
# Optional override for the OFSI consolidated sanctions list (defaults to the live URL).
# OFSI_CONSOLIDATED_LIST_URL=
# Didit — OPTIONAL, paid KYB/AML ($2/company). Leave blank to disable; the free
# official sources remain the source of truth.
# DIDIT_API_KEY=
# DIDIT_API_URL=
